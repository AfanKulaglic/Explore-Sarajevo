PORT=3001

# Database (for Prisma - only needed if you want to run migrations locally)
DATABASE_URL="postgresql://user:password@host:port/database"
DIRECT_URL="postgresql://user:password@host:port/database"

# Quiz Supabase (your quiz data database)
NEXT_PUBLIC_SUPABASE_URL="https://your-quiz-supabase.example.com"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_quiz_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_quiz_supabase_service_role_key"

# Admin Access (comma-separated emails)
ADMIN_EMAILS="admin1@example.com,admin2@example.com"

# Privacy & Security
# IMPORTANT: Change these peppers to random strings in production!
DEVICE_ID_PEPPER="your_random_string_here"
EMAIL_PEPPER="your_other_random_string_here"

# Central Account System (SSO)
# This is the central Supabase that handles authentication across all Saraya platforms
CENTRAL_API_URL="https://accounts.saraya.solutions"
NEXT_PUBLIC_AUTH_SUPABASE_URL="https://your-accounts-supabase.example.com"
NEXT_PUBLIC_AUTH_SUPABASE_ANON_KEY="your_accounts_supabase_anon_key"
CENTRAL_SUPABASE_SERVICE_KEY="your_accounts_supabase_service_role_key"

# SSO Configuration
NEXT_PUBLIC_ACCOUNTS_ORIGIN="https://accounts.saraya.solutions"
NEXT_PUBLIC_SSO_LINK_URL="https://accounts.saraya.solutions/api/auth/sso-link"
